# Copy to .env.local for local development. All values are optional —
# without them the site runs with the bundled sample gallery.

# URL of the deployed photo-feed Cloudflare Worker (see /worker).
# When unset, the gallery shows the illustrated sample photos.
# This is a public endpoint URL, not a secret.
VITE_PHOTOS_API_URL=

# Base path for the build. Defaults to /BlazesWorld/ (GitHub Pages project
# site). Set to / when deploying to a custom domain or user-root site.
VITE_BASE=
